        },
        "bodyParametersJson": "={{JSON.stringify({ messaging_product: \"whatsapp\", to: $node[\"Normalize Input\"].json.customerHandleOrPhone, type: \"text\", text: { body: ($json.choices?.[0]?.message?.content || $json.message?.content || $json.text || \"Can you please share a little more detail?\") } })}}"
      }
    },
    {
      "id": "UpdateLeadClarificationStatus",
      "name": "Update Lead Clarification Status",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [
        3060,
        -260
      ],
      "parameters": {
        "resource": "rows",
        "operation": "update",
        "tableId": "YOUR_TABLE_ID_LEADS",
        "updateKey": "leadId",
        "columns": "lastStatus",
        "values": "clarification_asked"
      },
      "credentials": {
        "n8nApi": "YOUR_N8N_DATATABLE_CREDS"
      }
    },
    {
      "id": "BuildSearchParams",
      "name": "Build Product Search Params",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        2400,
        20
      ],
      "parameters": {
        "functionCode": "const state = $json;\nconst normalized = $node['Normalize Input'].json;\nconst query = state.latestCustomerMessage || normalized.query || '';\nconst budget = normalized.budget || state.budget || null;\nlet minPrice = '';\nlet maxPrice = '';\nif (budget) { const b = Number(budget) || 0; minPrice = String(Math.max(0, Math.round(b * 0.5))); maxPrice = String(Math.round(b * 1.2)); }\nreturn [{ ...state, search: { leadId: state.leadId, q: query, category: '', occasion: normalized.occasion || '', minPrice, maxPrice, source: 'whatsapp', campaignName: normalized.campaignName || 'ai-commerce', couponCode: normalized.couponActive ? 'WELCOME10' : '', limit: 6 } }];"
      }
    },
    {
      "id": "ProductSearchRequest",
      "name": "Product Search Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        2620,
        20
      ],
      "parameters": {
        "authentication": "none",
        "method": "GET",
        "url": "={{`https://kpskrishnai.com/api/omnichannel/products/search?leadId=${encodeURIComponent($json.search.leadId || \"\")}&q=${encodeURIComponent($json.search.q)}&category=${encodeURIComponent($json.search.category)}&occasion=${encodeURIComponent($json.search.occasion)}&minPrice=${encodeURIComponent($json.search.minPrice)}&maxPrice=${encodeURIComponent($json.search.maxPrice)}&source=${encodeURIComponent($json.search.source)}&campaign=${encodeURIComponent($json.search.campaignName)}&coupon=${encodeURIComponent($json.search.couponCode)}&limit=${encodeURIComponent($json.search.limit)}`}}",
        "options": {}
      }
    },
    {
      "id": "CheckEmptyResults",
      "name": "Check Empty Results",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        2840,
        20
      ],
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{(($json.body?.products || $json.products || []).length)}}",
              "operation": "smaller",
              "value2": 1
            }
          ]
        }
      }
    },
    {
      "id": "ClarifyNoProducts",
      "name": "Clarify If No Products",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        3060,
        -60
      ],
      "parameters": {
        "resource": "chat",
        "operation": "chat",
        "model": "gpt-4.1-mini",
        "messages": {
          "values": [
            {
              "type": "system",
              "text": "No matching products were found. Ask one short clarifying question and offer human support. Keep it premium and polite."
            },
            {
              "type": "user",
              "text": "=Language: {{$node[\"Init WorkflowState\"].json.language}}\nCustomer message: {{$node[\"Init WorkflowState\"].json.latestCustomerMessage}}"
            }
          ]
        }
      },
      "credentials": {
        "openAiApi": "YOUR_OPENAI_API_CREDENTIAL"
      }
    },
    {
      "id": "SendNoProductClarificationWhatsApp",
      "name": "Send No-Product Clarification (WhatsApp)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        3280,
        -60
      ],
      "parameters": {
        "url": "https://graph.facebook.com/v19.0/YOUR_WHATSAPP_PHONE_NUMBER_ID/messages",
        "method": "POST",
        "authentication": "none",
        "jsonParameters": true,
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer YOUR_WHATSAPP_BEARER_TOKEN"
        },
        "bodyParametersJson": "={{JSON.stringify({ messaging_product: \"whatsapp\", to: $node[\"Normalize Input\"].json.customerHandleOrPhone, type: \"text\", text: { body: ($json.choices?.[0]?.message?.content || $json.message?.content || $json.text || \"Please share your budget or occasion and I will suggest closer options.\") } })}}"
      }
    },
    {
      "id": "TrimProducts",
      "name": "Trim Products to 6",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        3060,
        120
      ],
      "parameters": {
        "functionCode": "const response = $json.body || $json;\nconst products = Array.isArray(response) ? response : (response.products || []);\nconst mapped = products.slice(0, 6).map((p) => ({ name: p.name, price: p.price, shortBenefit: p.shortBenefit, imageUrl: p.imageUrl, productUrl: p.productUrl, buyNowUrl: p.buyNowUrl, checkoutUrl: p.checkoutUrl }));\nreturn [{ introMessage: response.introMessage || '', products: mapped }];"
      }
    },
    {
      "id": "GenerateProductReply",
      "name": "Generate Product Reply",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        3280,
        120
      ],
      "parameters": {
        "resource": "chat",
        "operation": "chat",
        "model": "gpt-4.1-mini",
        "messages": {
          "values": [
            {
              "type": "system",
              "text": "You are the Krishnai Pearl Shoppee WhatsApp assistant. Convert interest into website purchase. Use short premium English/Hindi/Hinglish. Start with one friendly recommendation line, list products with name, price and benefit, include provided Buy Now or Direct Checkout URLs, do not invent URLs, keep under 1200 characters, do not mention coupon codes."
            },
            {
              "type": "user",
              "text": "={{JSON.stringify({ language: $node[\"Init WorkflowState\"].json.language, intent: $node[\"Init WorkflowState\"].json.currentIntent, products: $json.products })}}"
            }
          ]
        }
      },
      "credentials": {
        "openAiApi": "YOUR_OPENAI_API_CREDENTIAL"
      }
    },
    {
      "id": "CreateApprovalCustomerReply",
      "name": "Create Approval (Customer Reply)",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        3500,
        120
      ],
      "parameters": {
        "functionCode": "const approvalId = 'apr_' + Date.now() + '_' + Math.random().toString(36).slice(2, 10);\nconst previewText = $json.choices?.[0]?.message?.content || $json.message?.content || $json.text || '';\nconst products = $node['Trim Products to 6'].json.products || [];\nreturn [{ approvalId, type: 'customer_reply', customerHandleOrPhone: $node['Normalize Input'].json.customerHandleOrPhone, previewText, imageUrls: products.map((p) => p.imageUrl).filter(Boolean), targetPlatforms: ['WHATSAPP'], coupon: null }];"
      }
    },
    {
      "id": "StoreApprovalCustomerReply",
      "name": "Store Approval (Customer Reply)",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [
        3720,
        120
      ],
      "parameters": {
        "resource": "rows",
        "operation": "create",
        "tableId": "YOUR_TABLE_ID_APPROVALS",
        "columns": "approvalId,leadId,type,customerHandleOrPhone,previewText,imageUrls,targetPlatforms,coupon,status,createdAt",
        "values": "={{$json.approvalId}},{{$node[\"Init WorkflowState\"].json.leadId}},customer_reply,{{$json.customerHandleOrPhone}},{{$json.previewText}},{{$json.imageUrls}},{{$json.targetPlatforms}},{{$json.coupon}},pending,={{new Date().toISOString()}}"
      },
      "credentials": {
        "n8nApi": "YOUR_N8N_DATATABLE_CREDS"
      }
    },
    {
      "id": "SendApprovalToOwnerCustomer",
      "name": "Send Approval to Owner (Customer Reply)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        3940,
        120
      ],
      "parameters": {
        "url": "https://graph.facebook.com/v19.0/YOUR_WHATSAPP_PHONE_NUMBER_ID/messages",
        "method": "POST",
        "authentication": "none",
        "jsonParameters": true,
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer YOUR_WHATSAPP_BEARER_TOKEN"
        },
        "bodyParametersJson": "={{JSON.stringify({ messaging_product: \"whatsapp\", to: \"YOUR_OWNER_WHATSAPP_NUMBER\", type: \"interactive\", interactive: { type: \"button\", body: { text: `New customer reply ready for approval.\nLead: ${$node[\"Init WorkflowState\"].json.leadId}\nApproval: ${$json.approvalId}\n\nPreview:\n${$json.previewText}` }, action: { buttons: [{ type: \"reply\", reply: { id: `APPROVE_${$json.approvalId}`, title: \"Approve\" } }, { type: \"reply\", reply: { id: `EDIT_${$json.approvalId}`, title: \"Edit\" } }, { type: \"reply\", reply: { id: `REJECT_${$json.approvalId}`, title: \"Reject\" } }] } } })}}"
      }
    },
    {
      "id": "BuildWebsiteCampaignPayload",
      "name": "Build Website Campaign Payload",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        2400,
        220
      ],
      "parameters": {
        "functionCode": "const normalized = $node['Normalize Input'].json;\nconst languageMap = { en: 'ENGLISH', english: 'ENGLISH', hi: 'HINGLISH', hindi: 'HINGLISH', hinglish: 'HINGLISH', mr: 'MARATHI', marathi: 'MARATHI' };\nconst language = languageMap[String(normalized.language || '').toLowerCase()] || 'HINGLISH';\nconst platforms = (normalized.targetPlatforms || ['WHATSAPP', 'INSTAGRAM', 'FACEBOOK']).map((entry) => String(entry).toUpperCase());\nconst campaignSlug = encodeURIComponent((normalized.campaignName || 'n8n-campaign').toLowerCase().replace(/[^a-z0-9]+/g, '-'));\nconst landingUrl = normalized.websiteBaseUrl + '/products?utm_source=n8n&utm_medium=manual_campaign&utm_campaign=' + campaignSlug;\nreturn [{ ...$json, websiteCampaign: { campaignName: normalized.campaignName || 'Manual Campaign', campaignType: 'CUSTOM', offerTitle: normalized.query || normalized.campaignName || 'New campaign', landingUrl, discountType: 'NONE', discountValue: null, targetPlatforms: platforms, language, tone: normalized.tone || 'PREMIUM' } }];"
      }
    },
    {
      "id": "CreateWebsiteCampaign",
      "name": "Create Campaign in Website",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        2620,
        220
      ],
      "parameters": {
        "url": "https://kpskrishnai.com/api/marketing/campaigns",
        "method": "POST",
        "authentication": "none",
        "jsonParameters": true,
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Basic YOUR_BASE64_ADMIN_COLON_PASSWORD"
        },
        "bodyParametersJson": "={{JSON.stringify($json.websiteCampaign)}}"
      }
    },
    {
      "id": "StartWebsiteCampaignGeneration",
      "name": "Start Website AI Draft Generation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        2840,
        220
      ],
      "parameters": {
