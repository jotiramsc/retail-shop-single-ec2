      "typeVersion": 1,
      "position": [
        200,
        -100
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "krishnai/whatsapp-inbound",
        "responseMode": "onReceived",
        "responseData": "default",
        "options": {}
      },
      "webhookId": "YOUR_WEBHOOK_ID_WHATSAPP"
    },
    {
      "id": "ManualCampaignWebhook",
      "name": "Manual Campaign Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        200,
        150
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "krishnai/manual-campaign",
        "responseMode": "onReceived",
        "responseData": "default",
        "options": {}
      },
      "webhookId": "YOUR_WEBHOOK_ID_MANUAL"
    },
    {
      "id": "MergeTriggers",
      "name": "Merge Triggers",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 1,
      "position": [
        420,
        20
      ],
      "parameters": {
        "mode": "passThrough"
      }
    },
    {
      "id": "NormalizeInput",
      "name": "Normalize Input",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        640,
        20
      ],
      "parameters": {
        "functionCode": "const req = $json;\nconst body = req.body || req;\nconst headers = req.headers || {};\nconst path = headers['x-n8n-webhook-path'] || headers['X-N8n-Webhook-Path'] || req.path || '';\nconst cloudValue = body.entry?.[0]?.changes?.[0]?.value || {};\nconst msg = body.messages?.[0] || cloudValue.messages?.[0] || body.message || {};\nconst contact = body.contacts?.[0] || cloudValue.contacts?.[0] || {};\nlet channel = path.includes('manual-campaign') || body.channel === 'manual_campaign' ? 'manual_campaign' : 'whatsapp';\nlet query = '';\nlet customerName = 'Customer';\nlet customerHandleOrPhone = '';\nlet sourceMessageId = '';\nlet language = 'auto';\nlet campaignName = null;\nlet budget = null;\nlet occasion = null;\nlet couponActive = false;\nlet targetPlatforms = ['WHATSAPP', 'INSTAGRAM', 'FACEBOOK'];\nlet tone = 'PREMIUM';\nif (channel === 'whatsapp') {\n  query = msg.text?.body || msg.interactive?.button_reply?.title || msg.button?.text || body.text || '';\n  customerHandleOrPhone = msg.from || body.from || body.mobile || body.customerHandleOrPhone || '';\n  sourceMessageId = msg.id || body.messageId || body.sourceMessageId || '';\n  customerName = contact.profile?.name || body.customerName || 'Customer';\n}\nif (channel === 'manual_campaign') {\n  query = body.goal || body.query || body.offerTitle || '';\n  campaignName = body.campaignName || body.name || 'Manual Campaign';\n  language = (body.language || 'hinglish').toLowerCase();\n  budget = body.budget || null;\n  occasion = body.occasion || null;\n  couponActive = Boolean(body.couponActive);\n  tone = (body.tone || 'PREMIUM').toUpperCase();\n  targetPlatforms = Array.isArray(body.targetPlatforms) && body.targetPlatforms.length ? body.targetPlatforms.map((entry) => String(entry).toUpperCase()) : targetPlatforms;\n}\nreturn [{ channel, customerName, customerHandleOrPhone, sourceMessageId, query, budget, occasion, language, campaignName, couponActive, targetPlatforms, tone, websiteBaseUrl: 'https://kpskrishnai.com', raw: body }];"
      }
    },
    {
      "id": "CreateLeadBackend",
      "name": "Create Lead (Website Backend)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        860,
        20
      ],
      "parameters": {
        "url": "https://kpskrishnai.com/api/omnichannel/leads",
        "method": "POST",
        "authentication": "none",
        "jsonParameters": true,
        "bodyParametersJson": "={{JSON.stringify({ channel: $json.channel, externalUserId: $json.customerHandleOrPhone, externalThreadId: $json.sourceMessageId, customerName: $json.customerName, mobile: $json.customerHandleOrPhone, sourceCampaign: $json.campaignName, productInterest: [$json.occasion, $json.budget].filter(Boolean).join(\" | \"), messageText: $json.query, rawPayload: JSON.stringify($json.raw) })}}"
      }
    },
    {
      "id": "StoreLeadInTable",
      "name": "Store Lead in Data Table",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [
        1080,
        20
      ],
      "parameters": {
        "resource": "rows",
        "operation": "create",
        "tableId": "YOUR_TABLE_ID_LEADS",
        "columns": "leadId,channel,sourceMessageId,customerName,customerHandleOrPhone,query,budget,occasion,language,campaignName,lastStatus,createdAt",
        "values": "={{$json.leadId || $json.id || $json.body?.leadId || $json.body?.id || \"\"}},{{$node[\"Normalize Input\"].json.channel}},{{$node[\"Normalize Input\"].json.sourceMessageId}},{{$node[\"Normalize Input\"].json.customerName}},{{$node[\"Normalize Input\"].json.customerHandleOrPhone}},{{$node[\"Normalize Input\"].json.query}},{{$node[\"Normalize Input\"].json.budget}},{{$node[\"Normalize Input\"].json.occasion}},{{$node[\"Normalize Input\"].json.language}},{{$node[\"Normalize Input\"].json.campaignName}},new,={{new Date().toISOString()}}"
      },
      "credentials": {
        "n8nApi": "YOUR_N8N_DATATABLE_CREDS"
      }
    },
    {
      "id": "ClassifyIntent",
      "name": "OpenAI - Classify Intent",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        1300,
        20
      ],
      "parameters": {
        "resource": "chat",
        "operation": "chat",
        "model": "gpt-4.1-mini",
        "messages": {
          "values": [
            {
              "type": "system",
              "text": "You are the Krishnai Pearl Shoppee conversational AI. Classify customer intent and extract info. Possible intents: product_search, price_inquiry, offer_inquiry, order_support, human_handoff, campaign_creation. campaign_creation is only for internal manual campaign webhook messages. Output ONLY valid JSON with keys: intent, confidence, language, query, budget, occasion, needClarification, clarificationQuestion. Use en, hi, or hinglish for language. Keep confidence below 0.6 when unsure."
            },
            {
              "type": "user",
              "text": "=Channel: {{$node[\"Normalize Input\"].json.channel}}\nCustomer name: {{$node[\"Normalize Input\"].json.customerName}}\nMessage: {{$node[\"Normalize Input\"].json.query}}"
            }
          ]
        }
      },
      "credentials": {
        "openAiApi": "YOUR_OPENAI_API_CREDENTIAL"
      }
    },
    {
      "id": "ParseIntentJson",
      "name": "Parse Intent JSON",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1520,
        20
      ],
      "parameters": {
        "functionCode": "const content = $json.choices?.[0]?.message?.content || $json.message?.content || $json.text || '{}';\ntry {\n  const fence = String.fromCharCode(96, 96, 96);\n  const cleaned = content.replace(fence + 'json', '').replace(fence, '').trim();\n  return [JSON.parse(cleaned)];\n} catch (e) {\n  return [{ intent: 'human_handoff', confidence: 0, language: 'en', query: $node['Normalize Input'].json.query, budget: null, occasion: null, needClarification: true, clarificationQuestion: 'Can you please tell me a bit more about what you are looking for?' }];\n}"
      }
    },
    {
      "id": "InitWorkflowState",
      "name": "Init WorkflowState",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1740,
        20
      ],
      "parameters": {
        "functionCode": "const leadBackend = $node['Create Lead (Website Backend)'].json;\nconst normalized = $node['Normalize Input'].json;\nconst intent = $json;\nconst stateId = 'state_' + Date.now() + '_' + Math.random().toString(36).slice(2, 10);\nconst leadId = leadBackend.leadId || leadBackend.id || leadBackend.body?.leadId || leadBackend.body?.id || '';\nreturn [{ stateId, leadId, channel: normalized.channel, currentIntent: normalized.channel === 'manual_campaign' ? 'campaign_creation' : intent.intent, openAiIntentConfidence: Number(intent.confidence || 0), productSearchParams: null, productSearchResults: null, language: intent.language || normalized.language || 'auto', latestCustomerMessage: normalized.query, ownerApprovalStatus: null, isCouponActive: normalized.couponActive, couponCode: normalized.couponActive ? 'WELCOME10' : '', approvalId: null, needClarification: Boolean(intent.needClarification), clarificationQuestion: intent.clarificationQuestion || '' }];"
      }
    },
    {
      "id": "StoreWorkflowState",
      "name": "Store WorkflowState",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [
        1960,
        20
      ],
      "parameters": {
        "resource": "rows",
        "operation": "create",
        "tableId": "YOUR_TABLE_ID_WORKFLOWSTATE",
        "columns": "stateId,leadId,channel,currentIntent,openAiIntentConfidence,language,latestCustomerMessage,ownerApprovalStatus,isCouponActive,couponCode,approvalId,needClarification,clarificationQuestion",
        "values": "={{$json.stateId}},{{$json.leadId}},{{$json.channel}},{{$json.currentIntent}},{{$json.openAiIntentConfidence}},{{$json.language}},{{$json.latestCustomerMessage}},{{$json.ownerApprovalStatus}},{{$json.isCouponActive}},{{$json.couponCode}},{{$json.approvalId}},{{$json.needClarification}},{{$json.clarificationQuestion}}"
      },
      "credentials": {
        "n8nApi": "YOUR_N8N_DATATABLE_CREDS"
      }
    },
    {
      "id": "RouteByIntent",
      "name": "Route by Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        2180,
        20
      ],
      "parameters": {
        "property": "={{$json.currentIntent}}",
        "rules": {
          "rules": [
            {
              "operation": "equal",
              "value": "campaign_creation"
            },
            {
              "operation": "equal",
              "value": "product_search"
            },
            {
              "operation": "equal",
              "value": "price_inquiry"
            },
            {
              "operation": "equal",
              "value": "offer_inquiry"
            },
            {
              "operation": "equal",
              "value": "order_support"
            },
            {
              "operation": "equal",
              "value": "human_handoff"
            }
          ]
        }
      }
    },
    {
      "id": "CheckConfidence",
      "name": "Check Confidence",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        2400,
        -120
      ],
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.openAiIntentConfidence}}",
              "operation": "smaller",
              "value2": 0.6
            }
          ]
        }
      }
    },
    {
      "id": "ClarificationMessage",
      "name": "Clarification Message",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        2620,
        -260
      ],
      "parameters": {
        "resource": "chat",
        "operation": "chat",
        "model": "gpt-4.1-mini",
        "messages": {
          "values": [
            {
              "type": "system",
              "text": "You are Krishnai Pearl Shoppee assistant. Ask exactly one short clarifying question and politely offer human help. Use the customer language. Keep under two short sentences."
            },
            {
              "type": "user",
              "text": "=Language: {{$json.language}}\nCustomer message: {{$json.latestCustomerMessage}}"
            }
          ]
        }
      },
      "credentials": {
        "openAiApi": "YOUR_OPENAI_API_CREDENTIAL"
      }
    },
    {
      "id": "SendClarificationWhatsApp",
      "name": "Send Clarification (WhatsApp)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        2840,
        -260
      ],
      "parameters": {
        "url": "https://graph.facebook.com/v19.0/YOUR_WHATSAPP_PHONE_NUMBER_ID/messages",
